#!/usr/bin/env python3
"""fit — lightweight CLI for the fitness tracker."""

import sys
import os

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from fitness_log import (
    log_session, get_recent_sessions, get_session,
    get_exercise_history, get_all_working_weights,
    get_body_comp_history, log_body_comp,
    update_working_weight, log_milestone
)

def cmd_status():
    print("=== WORKING WEIGHTS ===")
    weights = get_all_working_weights()
    if not weights:
        print("  No weights logged yet.")
    for w in weights:
        print(f"  {w['exercise']}: {w['weight']} {w['weight_unit']} ({w['date_set']})")

    print("\n=== RECENT SESSIONS ===")
    sessions = get_recent_sessions(5)
    if not sessions:
        print("  No sessions logged yet.")
    for s in sessions:
        print(f"  {s['date']} — {s['name']}")

    print("\n=== BODY COMP ===")
    comp = get_body_comp_history()
    if comp:
        latest = comp[0]
        print(f"  Latest: {latest['weight_lbs']} lbs | {latest['body_fat_pct']}% BF | VO2 {latest['vo2_max']} ({latest['date']})")
    else:
        print("  No entries.")

def cmd_history(exercise, limit=20):
    rows = get_exercise_history(exercise, limit)
    if not rows:
        print(f"No history for '{exercise}'.")
        return
    print(f"=== {exercise.upper()} ===")
    current_date = None
    for r in rows:
        if r['date'] != current_date:
            current_date = r['date']
            print(f"\n  {r['date']} — {r['session_name']}")
        rpe_str = f" @ RPE {r['rpe']}" if r['rpe'] else ""
        dur_str = f" ({r['duration_sec']}s)" if r['duration_sec'] else ""
        print(f"    Set {r['set_number']}: {r['reps']} reps x {r['weight']} {r['weight_unit']}{rpe_str}{dur_str}")

def cmd_weights():
    weights = get_all_working_weights()
    if not weights:
        print("No working weights logged yet.")
        return
    max_name = max(len(w['exercise']) for w in weights)
    print(f"  {'Exercise':<{max_name}}   Weight       Date Set")
    print(f"  {'-' * max_name}   ----------   ----------")
    for w in weights:
        print(f"  {w['exercise']:<{max_name}}   {w['weight']:>6} {w['weight_unit']:<3}   {w['date_set']}")

def cmd_bodycomp():
    comp = get_body_comp_history()
    if not comp:
        print("No body comp entries.")
        return
    print(f"  {'Date':<12} {'Weight':>8} {'BF%':>6} {'Lean':>8} {'VO2':>5}")
    print(f"  {'-'*12} {'-'*8} {'-'*6} {'-'*8} {'-'*5}")
    for b in comp:
        wt = f"{b['weight_lbs']}" if b['weight_lbs'] else "—"
        bf = f"{b['body_fat_pct']}%" if b['body_fat_pct'] else "—"
        lm = f"{b['lean_mass_lbs']}" if b['lean_mass_lbs'] else "—"
        vo = f"{b['vo2_max']}" if b['vo2_max'] else "—"
        print(f"  {b['date']:<12} {wt:>8} {bf:>6} {lm:>8} {vo:>5}")

def cmd_session(session_id):
    try:
        s = get_session(int(session_id))
    except Exception:
        print(f"Session {session_id} not found.")
        return
    print(f"=== {s['date']} — {s['name']} ===")
    if s.get('block'):
        print(f"Block: {s['block']} | Week: {s.get('week', '—')}")
    if s.get('notes'):
        print(f"Notes: {s['notes']}")
    print()
    current_exercise = None
    for st in s['sets']:
        if st['exercise'] != current_exercise:
            current_exercise = st['exercise']
            print(f"  {current_exercise}")
        rpe_str = f" @ RPE {st['rpe']}" if st['rpe'] else ""
        dur_str = f" ({st['duration_sec']}s)" if st['duration_sec'] else ""
        cal_str = " [CAL]" if st['is_calibration'] else ""
        print(f"    Set {st['set_number']}: {st['reps']} x {st['weight']} {st['weight_unit']}{rpe_str}{dur_str}{cal_str}")

def cmd_help():
    print("""fit — fitness tracker CLI

Usage:
  fit status              Overview: working weights, recent sessions, body comp
  fit weights             All current working weights
  fit history <exercise>  Set history for an exercise (e.g. "Lat Pulldown")
  fit session <id>        Full detail for a logged session
  fit bodycomp            Body composition history
  fit help                This message

Logging is done through Droid — just tell your coach what you did.""")

def main():
    if len(sys.argv) < 2:
        cmd_status()
        return

    command = sys.argv[1].lower()

    if command == "status":
        cmd_status()
    elif command == "weights":
        cmd_weights()
    elif command == "history":
        if len(sys.argv) < 3:
            print("Usage: fit history <exercise name>")
            return
        exercise = " ".join(sys.argv[2:])
        cmd_history(exercise)
    elif command == "session":
        if len(sys.argv) < 3:
            print("Usage: fit session <id>")
            return
        cmd_session(sys.argv[2])
    elif command == "bodycomp":
        cmd_bodycomp()
    elif command == "help" or command == "--help" or command == "-h":
        cmd_help()
    else:
        print(f"Unknown command: {command}")
        cmd_help()

if __name__ == "__main__":
    main()
